# Copy this file to .env and fill in your values

# Solana Network
SOLANA_NETWORK=devnet
SOLANA_RPC=https://api.devnet.solana.com

# Port
PORT=5000

# Master Wallet Secret Key (KEEP SECURE!)
# Generate with: solana-keygen new
# Get as JSON array: solana config get keypair-path, then cat the file
# For development only - NEVER put real funds here
MASTER_WALLET_SECRET=

# Encryption
ENCRYPTION_KEY=your-random-secret-key-change-in-production
